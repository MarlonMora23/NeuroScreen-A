# Environment Variables - NeuroScreen-A

# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Database
POSTGRES_USER=eeguser
POSTGRES_PASSWORD=eegpassword
POSTGRES_DB=eegdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://eeguser:eegpassword@db:5432/eegdb

# Admin User
ADMIN_PASSWORD=Admin123

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600


# File Upload
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=/app/uploads

# Redis URL for rate limiting (used by Flask-Limiter)
REDIS_URL=memory://