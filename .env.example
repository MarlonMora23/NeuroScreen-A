# Environment Variables - NeuroScreen-A (DEVELOPMENT)
# This file contains environment variables for the development environment of the NeuroScreen-A application.
# Make sure to change the values in production and keep this file secure.

# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Database
POSTGRES_USER=eeguser
POSTGRES_DB=eegdb
POSTGRES_PASSWORD=eegpassword
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://eeguser:eegpassword@db:5432/eegdb

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
SESSION_DURATION_MINUTES=30

# Redis
REDIS_PASSWORD=your-redis-password-change-in-production
REDIS_URL=redis://:your-redis-password-change-in-production@redis:6379/0
CELERY_BROKER_URL=redis://:your-redis-password-change-in-production@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password-change-in-production@redis:6379/0

# App Settings
ADMIN_EMAIL=admin@neuroscreen.com
ADMIN_PASSWORD=Admin123

# Frontend
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=/api
VITE_BASE=/

# CORS - Desarrollo
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:80,http://localhost,http://frontend:80,http://frontend
ALLOWED_HOSTS=localhost,127.0.0.1,api,frontend

# File Upload
SAVE_EEG_FILES=true
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=/app/uploads
